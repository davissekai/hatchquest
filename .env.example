# ============================================================
# HatchQuest — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
#
#   cp .env.example .env.local
# ============================================================

# Supabase — get these from your Supabase project dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — server-side only, never expose to the client
# Project Settings → API → service_role (keep this secret)
SUPABASE_SERVICE_ROLE_KEY=

# Database URL — used by Drizzle for migrations
# Project Settings → Database → Connection string (Transaction mode)
DATABASE_URL=

# NVIDIA Inference — used by Layer 0 classifier (MiniMax M2.7 via NVIDIA NIM)
# Get from: https://build.nvidia.com → API Key
# Backend only — never expose this to the frontend
NVIDIA_API_KEY=
